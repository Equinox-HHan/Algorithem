{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C++ 编译 (GCC MSYS2)",
            "type": "shell",
            "command": "D:/mys64/ucrt64/bin/g++.exe",
            "args": [
                "-std=c++17",
                "-O2",
                "-Wall",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        }
    ]
}
